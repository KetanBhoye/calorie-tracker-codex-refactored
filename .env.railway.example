# Railway deployment environment variables
# Copy these to Railway's Variables tab in your project settings

PORT=8787
DATABASE_PATH=/app/data/calorie-tracker.db
NODE_ENV=production

# Required: Generate a strong random secret (32+ chars)
# Use: openssl rand -hex 32
ADMIN_API_KEY=your-strong-32-char-random-string-here

# Required: Admin account credentials for web login
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your-strong-password-here

# Session TTL for web login cookies (hours)
SESSION_TTL_HOURS=168

# Required: Railway auto-resolves this to your public domain
# Use exactly as shown below - Railway will replace it automatically
BASE_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
