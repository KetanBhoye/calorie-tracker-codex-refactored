{
  "name": "calorie-tracker-codex-refactored",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx/esm src/index.ts",
    "start": "node --import tsx/esm src/index.ts",
    "build": "vite build",
    "format": "biome format --write",
    "lint:fix": "biome lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node --import tsx/esm src/scripts/migrate.ts",
    "food:library": "node --import tsx/esm src/scripts/build-food-library.ts",
    "food:seed": "node --import tsx/esm src/scripts/seed-curated-foods.ts",
    "web:dev": "vite",
    "web:build": "vite build",
    "web:type-check": "vue-tsc --noEmit -p web/tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.10.0",
    "express": "^4.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.23",
    "@types/node": "^22.15.21",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/ui": "^3.2.2",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.2.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "pnpm@9.11.0+sha512.0a203ffaed5a3f63242cd064c8fb5892366c103e328079318f78062f24ea8c9d50bc6a47aa3567cabefd824d170e78fa2745ed1f16b132e16436146b7688f19b"
}
