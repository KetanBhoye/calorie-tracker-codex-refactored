# Railway deployment ignore file
# These files/directories won't be uploaded to Railway

# Development
node_modules/
.git/
# NB: .github as a whole must NOT be excluded — bootstrap seeds tracking
# preferences from .github/instructions, and the food library seeder reads the
# curated macros cache from there. A "!.github/instructions/" negation does not
# work: like gitignore, a path inside an excluded directory cannot be
# re-included. So exclude only the parts that aren't needed at runtime.
.github/workflows/
.github/copilot-instructions.md

# Environment files (set via Railway variables instead)
.env
.env.*
!.env.railway.example

# Local data
data/
*.db
*.db-shm
*.db-wal

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Testing
coverage/
.vitest/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/

# Documentation (not needed at runtime)
README.md
deploy/windows/

# Other
.editorconfig
