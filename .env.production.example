# Copy to .env.production before first deploy
# PowerShell: Copy-Item .env.production.example .env.production

PORT=8787
DATABASE_PATH=/data/calorie-tracker.db

# Required: strong random secret (32+ chars)
ADMIN_API_KEY=replace-with-strong-admin-api-key

# Required: seeded admin web account (used for OAuth approve step)
ADMIN_EMAIL=replace-with-admin-email@example.com
ADMIN_PASSWORD=replace-with-strong-password

# Required after Funnel URL is known (must be public HTTPS origin)
BASE_URL=https://replace-with-your-funnel-domain

# Session TTL for web login cookies
SESSION_TTL_HOURS=168
